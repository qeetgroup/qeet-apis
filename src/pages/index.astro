---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHead from "../components/SectionHead.astro";
import Icon from "../components/Icon.astro";
import CodeTabs from "../components/CodeTabs.astro";
import { LINKS } from "../data/catalog";

// 1 · Hero + trust
import Hero from "../components/Hero.astro";
import TrustedBy from "../components/TrustedBy.astro";
import LogoMarquee from "../components/LogoMarquee.astro";
// 3 · Platform
import PlatformOverview from "../components/PlatformOverview.astro";
import ProductSuite from "../components/ProductSuite.astro";
import MetricBand from "../components/MetricBand.astro";
// 4–13 · Capabilities
import ApiDiscovery from "../components/ApiDiscovery.astro";
import DocsPreview from "../components/DocsPreview.astro";
import ApiPlayground from "../components/ApiPlayground.astro";
import Authentication from "../components/Authentication.astro";
import SdkGeneration from "../components/SdkGeneration.astro";
import PlatformMetrics from "../components/PlatformMetrics.astro";
import ApiAnalytics from "../components/ApiAnalytics.astro";
import ApiMonitoring from "../components/ApiMonitoring.astro";
import RateLimiting from "../components/RateLimiting.astro";
import ApiVersioning from "../components/ApiVersioning.astro";
import Webhooks from "../components/Webhooks.astro";
// 14–17 · Enterprise, team, CLI, integrations
import EnterpriseGrid from "../components/EnterpriseGrid.astro";
import TeamCollaboration from "../components/TeamCollaboration.astro";
import CliExperience from "../components/CliExperience.astro";
import Integrations from "../components/Integrations.astro";
// 19–22 · Social proof → conversion
import Testimonials from "../components/Testimonials.astro";
import PricingPreview from "../components/PricingPreview.astro";
import FAQ from "../components/FAQ.astro";
import CalloutCTA from "../components/CalloutCTA.astro";

// --- Developer-experience quickstart (section 18) --------------------------
const firstRequest = [
  {
    label: "cURL",
    lang: "bash",
    code: `curl https://api.id.qeet.in/v1/auth/me \\
  -H "Authorization: ApiKey qk_live_..."`,
  },
  {
    label: "JavaScript",
    lang: "js",
    code: `const res = await fetch("https://api.id.qeet.in/v1/auth/me", {
  headers: { Authorization: "ApiKey qk_live_..." },
});
const principal = await res.json();`,
  },
  {
    label: "Go",
    lang: "go",
    code: `req, _ := http.NewRequest("GET", "https://api.id.qeet.in/v1/auth/me", nil)
req.Header.Set("Authorization", "ApiKey qk_live_...")
res, _ := http.DefaultClient.Do(req)`,
  },
  {
    label: "Python",
    lang: "python",
    code: `import requests

res = requests.get(
    "https://api.id.qeet.in/v1/auth/me",
    headers={"Authorization": "ApiKey qk_live_..."},
)
print(res.json())`,
  },
];

const codeChip =
  "rounded border border-rule bg-surface-2 px-1 font-mono text-[0.82em] text-brand-deep";
const steps = [
  `<b class="text-ink font-semibold">Create an API key</b> in the Qeet console for the product you want to call.`,
  `<b class="text-ink font-semibold">Send the key</b> as <code class="${codeChip}">Authorization: ApiKey &lt;key&gt;</code> (Qeet ID) or <code class="${codeChip}">X-Qeet-Api-Key</code> (Qeet Notify).`,
  `<b class="text-ink font-semibold">Call any endpoint</b> — start with the authenticated principal, then explore the rest in the reference.`,
];
---

<BaseLayout title="Qeet APIs — One platform for every API your business needs">
  <!-- 1 · Hero -->
  <Hero />

  <!-- 2 · Trusted by developers -->
  <TrustedBy />

  <!-- 2b · Open standards marquee -->
  <section class="border-y border-rule py-8">
    <div class="container container-wide">
      <p class="mb-5 text-center font-ui text-[0.8rem] font-semibold uppercase tracking-[0.16em] text-ink-faint">
        Speaks the open standards you already trust
      </p>
      <LogoMarquee />
    </div>
  </section>

  <!-- 3 · Platform overview -->
  <PlatformOverview />

  <!-- 3b · Product suite -->
  <section class="py-[clamp(3.5rem,8vw,6.5rem)]" id="products">
    <div class="container container-wide">
      <SectionHead
        class="mb-11"
        eyebrow="The suite"
        title="Best-of-breed products, one integration."
      >
        Each product is independently useful and shares a single platform for
        identity, notifications and audit. Two APIs are live today, with more on
        the way.
      </SectionHead>
      <ProductSuite />
    </div>
  </section>

  <!-- 3c · Reliability band (dark) -->
  <MetricBand />

  <!-- 4 · API Discovery -->
  <ApiDiscovery />

  <!-- 5 · API Documentation -->
  <section class="border-y border-rule bg-surface py-[clamp(3.5rem,8vw,6.5rem)]" id="docs">
    <div class="container container-wide">
      <SectionHead
        class="mb-11"
        eyebrow="API Documentation"
        title="Docs that read like a product."
      >
        Everything you need to go from first request to production — quickstart,
        authentication, errors, SDKs and a live, runnable reference.
      </SectionHead>
      <DocsPreview />
    </div>
  </section>

  <!-- 6 · API Playground -->
  <ApiPlayground />

  <!-- 7 · Authentication & Authorization -->
  <Authentication />

  <!-- 8 · SDK Generation -->
  <SdkGeneration />

  <!-- 8b · Platform metrics (dark) -->
  <PlatformMetrics />

  <!-- 9 · API Analytics -->
  <ApiAnalytics />

  <!-- 10 · API Monitoring -->
  <ApiMonitoring />

  <!-- 11 · Rate Limiting -->
  <RateLimiting />

  <!-- 12 · API Versioning -->
  <ApiVersioning />

  <!-- 13 · Webhooks -->
  <Webhooks />

  <!-- 14 · Enterprise Security -->
  <section class="border-y border-rule bg-surface py-[clamp(3.5rem,8vw,6.5rem)]" id="enterprise">
    <div class="container container-wide">
      <SectionHead
        class="mb-11"
        eyebrow="Enterprise Security"
        title="Ready for your security review."
      >
        SSO, RBAC, audit and least-privilege access are first-class across the
        platform — capabilities of the live specs, not bolt-on add-ons.
      </SectionHead>
      <EnterpriseGrid />
    </div>
  </section>

  <!-- 15 · Team Collaboration -->
  <TeamCollaboration />

  <!-- 16 · CLI Experience (dark) -->
  <CliExperience />

  <!-- 17 · Integrations -->
  <Integrations />

  <!-- 18 · Developer Experience -->
  <section class="py-[clamp(3.5rem,8vw,6.5rem)]" id="quickstart">
    <div class="container container-wide grid items-start gap-12 lg:grid-cols-2">
      <div>
        <SectionHead eyebrow="Developer Experience" title="Your first request in under a minute.">
          No SDK to install, no boilerplate. Grab a key, send a header, and you're
          talking to production.
        </SectionHead>
        <ol class="m-0 mt-7 grid list-none gap-4 p-0">
          {
            steps.map((s, i) => (
              <li class="flex gap-3 text-ink-muted" data-reveal>
                <span class="grid h-[1.9rem] w-[1.9rem] flex-none place-items-center rounded-full bg-brand-soft font-ui text-[0.9rem] font-semibold text-brand-deep">
                  {i + 1}
                </span>
                <span class="pt-0.5" set:html={s} />
              </li>
            ))
          }
        </ol>
        <div class="mt-7 flex flex-wrap gap-3.5" data-reveal>
          <a class="btn btn-primary" href={LINKS.quickstart}>
            <Icon name="zap" /> Full quickstart
          </a>
          <a class="btn" href={LINKS.authentication}>
            <Icon name="key" /> Authentication
          </a>
        </div>
      </div>
      <div data-reveal style="transition-delay:120ms">
        <CodeTabs tabs={firstRequest} />
      </div>
    </div>
  </section>

  <!-- 19 · Testimonials -->
  <Testimonials />

  <!-- 20 · Pricing preview -->
  <PricingPreview />

  <!-- 21 · FAQ -->
  <FAQ />

  <!-- 22 · Final CTA -->
  <CalloutCTA
    title="Build on Qeet APIs."
    text="One platform for every API your business needs. Discover, integrate, secure, monitor and scale — starting with your first request today."
    primary={{ href: LINKS.reference, label: "Open the API Reference", icon: "book" }}
    secondary={{ href: LINKS.console, label: "Go to Console", icon: "arrow-up-right", external: true }}
  />
</BaseLayout>

<script>
  // Dependency-free scroll choreography: reveal-on-view + count-up.
  (() => {
    const root = document.documentElement;
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const revealAll = () => root.classList.add("anim-fallback");

    if (reduce || !("IntersectionObserver" in window)) {
      revealAll();
      return;
    }

    try {
      // 1) Reveal elements as they scroll into view.
      const revealIO = new IntersectionObserver(
        (entries, obs) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            e.target.classList.add("is-in");
            obs.unobserve(e.target);
          }
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
      );
      document.querySelectorAll("[data-reveal]").forEach((el) => revealIO.observe(el));

      // 2) Count-up numbers when their stat scrolls in.
      const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
      const countUp = (el: HTMLElement) => {
        const target = Number(el.dataset.count || "0");
        const suffix = el.dataset.suffix || "";
        const dur = 1300;
        const start = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - start) / dur, 1);
          el.textContent = Math.round(easeOut(p) * target) + suffix;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };
      const countIO = new IntersectionObserver(
        (entries, obs) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            countUp(e.target as HTMLElement);
            obs.unobserve(e.target);
          }
        },
        { threshold: 0.6 },
      );
      document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => countIO.observe(el));
    } catch {
      revealAll();
    }
  })();
</script>
