---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ApiCatalog from "../components/ApiCatalog.astro";
import FeatureCard from "../components/FeatureCard.astro";
import CodeTabs from "../components/CodeTabs.astro";
import CalloutCTA from "../components/CalloutCTA.astro";
import Icon from "../components/Icon.astro";
import { LINKS } from "../data/catalog";

const firstRequest = [
  {
    label: "cURL",
    lang: "bash",
    code: `curl https://api.id.qeet.in/v1/auth/me \\
  -H "Authorization: ApiKey qk_live_..."`,
  },
  {
    label: "JavaScript",
    lang: "js",
    code: `const res = await fetch("https://api.id.qeet.in/v1/auth/me", {
  headers: { Authorization: "ApiKey qk_live_..." },
});
const principal = await res.json();`,
  },
  {
    label: "Go",
    lang: "go",
    code: `req, _ := http.NewRequest("GET", "https://api.id.qeet.in/v1/auth/me", nil)
req.Header.Set("Authorization", "ApiKey qk_live_...")
res, _ := http.DefaultClient.Do(req)`,
  },
  {
    label: "Python",
    lang: "python",
    code: `import requests

res = requests.get(
    "https://api.id.qeet.in/v1/auth/me",
    headers={"Authorization": "ApiKey qk_live_..."},
)
print(res.json())`,
  },
];

const codeChip =
  "rounded border border-rule bg-surface-2 px-1 font-mono text-[0.82em] text-brand-deep";
const steps = [
  `<b class="text-ink font-semibold">Create an API key</b> in the Qeet console for the product you want to call.`,
  `<b class="text-ink font-semibold">Send the key</b> as <code class="${codeChip}">Authorization: ApiKey &lt;key&gt;</code> (Qeet ID) or <code class="${codeChip}">X-Qeet-Api-Key</code> (Qeet Notify).`,
  `<b class="text-ink font-semibold">Call any endpoint</b> — start with the authenticated principal, then explore the rest in the reference.`,
];

const sectionHead = "mb-10 max-w-[52ch]";
const h2 = "mt-2.5 text-[clamp(1.8rem,3.5vw,2.6rem)]";
---

<BaseLayout title="Qeet APIs">
  <Hero />

  <!-- API catalog -->
  <section class="py-[clamp(3.5rem,8vw,6.5rem)]" id="apis">
    <div class="container container-wide">
      <div class={sectionHead}>
        <span class="eyebrow">Catalog</span>
        <h2 class={h2}>Every Qeet API, one reference.</h2>
        <p class="mt-3.5 text-[1.05rem] text-ink-muted">
          Browse the full surface across products. Each reference is generated
          from a versioned OpenAPI&nbsp;3.1 spec, with a live request console.
        </p>
      </div>
      <ApiCatalog />
    </div>
  </section>

  <!-- features -->
  <section class="border-y border-rule bg-surface py-[clamp(3.5rem,8vw,6.5rem)]">
    <div class="container container-wide">
      <div class={sectionHead}>
        <span class="eyebrow">Why developers ship faster</span>
        <h2 class={h2}>A reference that works like a tool.</h2>
      </div>
      <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
        <FeatureCard icon="terminal" title="Live request console">
          Authenticate and run any endpoint right from the browser — no Postman
          round-trip required.
        </FeatureCard>
        <FeatureCard icon="code" title="Code in your language">
          Copy ready-to-run snippets for cURL, JavaScript, Go, Python and more,
          generated per endpoint.
        </FeatureCard>
        <FeatureCard icon="search" title="Instant search">
          Jump to any endpoint, parameter or schema across every product in a
          keystroke.
        </FeatureCard>
        <FeatureCard icon="key" title="One credential, every API">
          A single API key or OAuth token explores the whole Qeet platform.
        </FeatureCard>
        <FeatureCard icon="layers" title="Always in sync">
          Docs are generated directly from each service's OpenAPI&nbsp;3.1 spec —
          never stale, never hand-written.
        </FeatureCard>
        <FeatureCard icon="shield" title="Built for enterprise">
          Scopes, audit trails, rate limits and multi-tenancy are first-class
          across the surface.
        </FeatureCard>
      </div>
    </div>
  </section>

  <!-- quickstart teaser -->
  <section class="py-[clamp(3.5rem,8vw,6.5rem)]" id="quickstart">
    <div class="container container-wide grid items-start gap-12 lg:grid-cols-2">
      <div>
        <span class="eyebrow">Quickstart</span>
        <h2 class={`${h2} mb-6`}>Your first request in under a minute.</h2>
        <ol class="m-0 grid list-none gap-4 p-0">
          {
            steps.map((s, i) => (
              <li class="flex gap-3 text-ink-muted">
                <span class="grid h-[1.9rem] w-[1.9rem] flex-none place-items-center rounded-full bg-brand-soft font-ui text-[0.9rem] font-semibold text-brand-deep">
                  {i + 1}
                </span>
                <span class="pt-0.5" set:html={s} />
              </li>
            ))
          }
        </ol>
        <div class="mt-7 flex flex-wrap gap-3.5">
          <a class="btn btn-primary" href={LINKS.quickstart}>
            <Icon name="zap" /> Full quickstart
          </a>
          <a class="btn" href={LINKS.authentication}>
            <Icon name="key" /> Authentication
          </a>
        </div>
      </div>
      <CodeTabs tabs={firstRequest} />
    </div>
  </section>

  <CalloutCTA
    title="Build on Qeet."
    text="Open the interactive reference, authenticate, and ship your first integration today."
    primary={{ href: LINKS.reference, label: "Open the API Reference", icon: "book" }}
    secondary={{ href: LINKS.console, label: "Go to Console", icon: "arrow-up-right", external: true }}
  />
</BaseLayout>
