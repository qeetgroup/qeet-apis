---
import Icon from "./Icon.astro";
import { ENTERPRISE } from "../data/catalog";
---

<!-- Spec-sheet layout: hairline-separated rows (1px gaps reveal the container's
     rule colour) — deliberately distinct from the bordered DX feature cards. -->
<div class="grid gap-px overflow-hidden rounded-2xl border border-rule bg-rule sm:grid-cols-2">
  {
    ENTERPRISE.map((e, i) => (
      <div
        class="group flex items-start gap-4 bg-surface p-6 transition-colors duration-200 hover:bg-surface-2"
        data-reveal
        style={`transition-delay:${i * 45}ms`}
      >
        <span class="grid h-[2.7rem] w-[2.7rem] flex-none place-items-center rounded-lg bg-brand-soft text-brand-deep transition-transform duration-300 group-hover:scale-110">
          <Icon name={e.icon as any} class="h-[1.35rem] w-[1.35rem]" />
        </span>
        <div>
          <h3 class="text-[1.08rem]">{e.title}</h3>
          <p class="m-0 mt-1 text-[0.93rem] text-ink-subtle">{e.body}</p>
        </div>
      </div>
    ))
  }
</div>
