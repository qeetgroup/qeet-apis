---
// API Discovery — a command-palette search over every product's surface.
// Split layout, visual on the right. Canvas background.
import SectionHead from "./SectionHead.astro";
import ArrowLink from "./ArrowLink.astro";
import Icon from "./Icon.astro";
import { LINKS } from "../data/catalog";

const bullets = [
  ["Unified search.", "One bar across every product — endpoints, parameters, schemas and error codes."],
  ["Command palette.", "Open ⌘K from anywhere and jump to any operation in a single keystroke."],
  ["Faceted filters.", "Narrow by product, HTTP method, tag or required scope as you type."],
  ["Never stale.", "The index is generated from OpenAPI 3.1 — new endpoints appear the moment they ship."],
];

const method = (m: string) =>
  ({ GET: "--m-get", POST: "--m-post", PUT: "--m-put", PATCH: "--m-patch", DELETE: "--m-delete" })[m] ?? "--m-get";

const results = [
  { m: "POST", path: "/v1/users", tag: "Qeet ID", active: true },
  { m: "GET", path: "/v1/users/{id}", tag: "Qeet ID", active: false },
  { m: "POST", path: "/v1/organizations", tag: "Qeet ID", active: false },
  { m: "POST", path: "/v1/messages", tag: "Qeet Notify", active: false },
  { m: "GET", path: "/v1/audit/events", tag: "Qeet ID", active: false },
];
---

<section class="py-[clamp(3.5rem,8vw,6.5rem)]" id="discovery">
  <div class="container container-wide">
    <div class="grid items-center gap-x-14 gap-y-10 lg:grid-cols-2">
      <!-- copy -->
      <div>
        <SectionHead eyebrow="API Discovery" title="Find any endpoint in a keystroke.">
          Two hundred and fifty-plus operations across products — searchable,
          filterable and instantly reachable. Discovery is a feature, not a scroll.
        </SectionHead>
        <ul class="mt-7 grid gap-4">
          {
            bullets.map(([h, t]) => (
              <li class="flex gap-3" data-reveal>
                <span class="mt-px grid h-5 w-5 flex-none place-items-center rounded-full bg-brand-soft text-brand-deep">
                  <Icon name="check" class="h-3 w-3" />
                </span>
                <span class="text-[0.96rem] text-ink-muted">
                  <b class="font-semibold text-ink">{h}</b> {t}
                </span>
              </li>
            ))
          }
        </ul>
        <div class="mt-8" data-reveal>
          <ArrowLink href={LINKS.reference} label="Browse the full catalog" />
        </div>
      </div>

      <!-- visual: command palette -->
      <div data-reveal style="transition-delay:120ms">
        <div class="relative">
          <div
            class="pointer-events-none absolute -inset-6 opacity-60 blur-2xl"
            style="background:radial-gradient(60% 60% at 60% 20%, var(--brand-soft), transparent 70%)"
            aria-hidden="true"
          >
          </div>
          <div class="bezel relative">
            <div class="bezel-core overflow-hidden">
            <!-- search bar -->
            <div class="flex items-center gap-3 border-b border-rule px-4 py-3.5">
              <Icon name="search" class="h-4 w-4 flex-none stroke-[1.55] text-ink-faint" />
              <span class="font-mono text-[0.9rem] text-ink"
                >create user<span class="caret"></span></span
              >
              <span
                class="ml-auto inline-flex items-center gap-1 rounded-md border border-rule bg-surface-2 px-1.5 py-1 font-mono text-[0.68rem] text-ink-faint"
              >
                <Icon name="command" class="h-3 w-3 stroke-[1.55]" />K
              </span>
            </div>

            <!-- filter chips -->
            <div class="flex items-center gap-1.5 border-b border-rule bg-surface-2/60 px-3 py-2">
              {
                ["All", "Qeet ID", "Notify", "POST"].map((f, i) => (
                  <span
                    class={`rounded-full px-2.5 py-1 font-ui text-[0.72rem] font-medium ${i === 0 ? "bg-brand-soft text-brand-deep" : "text-ink-subtle"}`}
                  >
                    {f}
                  </span>
                ))
              }
              <span class="ml-auto font-ui text-[0.72rem] text-ink-faint">28 results</span>
            </div>

            <!-- results -->
            <ul class="m-0 list-none p-1.5">
              {
                results.map((r) => (
                  <li
                    class={`flex items-center gap-3 rounded-lg px-3 py-2.5 ${r.active ? "bg-brand-faint" : ""}`}
                  >
                    <span
                      class="w-12 flex-none rounded px-1.5 py-0.5 text-center font-mono text-[0.66rem] font-semibold uppercase"
                      style={`color:var(${method(r.m)});background:color-mix(in oklab,var(${method(r.m)}) 12%,transparent)`}
                    >
                      {r.m}
                    </span>
                    <code class="flex-1 truncate font-mono text-[0.82rem] text-ink">{r.path}</code>
                    <span class="hidden font-ui text-[0.72rem] text-ink-faint sm:inline">{r.tag}</span>
                    {r.active && (
                      <span class="inline-flex items-center gap-1 rounded border border-rule bg-surface px-1.5 py-0.5 font-mono text-[0.64rem] text-ink-faint">
                        ↵
                      </span>
                    )}
                  </li>
                ))
              }
            </ul>

            <!-- footer -->
            <div
              class="flex items-center gap-4 border-t border-rule bg-surface-2/60 px-4 py-2 font-ui text-[0.7rem] text-ink-faint"
            >
              <span class="flex items-center gap-1.5"><kbd class="font-mono">↑↓</kbd> navigate</span>
              <span class="flex items-center gap-1.5"><kbd class="font-mono">↵</kbd> open</span>
              <span class="ml-auto flex items-center gap-1.5">
                <span class="live-dot h-1.5 w-1.5 rounded-full bg-success"></span> indexed live
              </span>
            </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
