---
import { TECH } from "../data/catalog";
// Duplicated once so the -50% marquee keyframe loops seamlessly.
const row = [...TECH, ...TECH];
---

<div class="marquee relative w-full overflow-hidden py-1">
  <ul class="marquee-track m-0 list-none gap-3 p-0">
    {
      row.map((t, i) => (
        <li aria-hidden={i >= TECH.length ? "true" : undefined}>
          <span class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border border-rule bg-surface px-4 py-2 font-ui text-[0.85rem] font-medium text-ink-muted">
            <span class="h-1.5 w-1.5 rounded-full bg-brand" aria-hidden="true"></span>
            {t}
          </span>
        </li>
      ))
    }
  </ul>
</div>
