---
import Icon from "./Icon.astro";
import { PRICING_TIERS, LINKS } from "../data/catalog";
---

<section class="py-[clamp(3.5rem,8vw,6.5rem)]" id="pricing">
  <div class="container container-wide">
    <div class="mb-12 max-w-[54ch]" data-reveal>
      <span class="eyebrow inline-flex items-center gap-2.5">
        <span class="h-px w-7 bg-brand/60"></span>
        Pricing
      </span>
      <h2 class="mt-3 text-[clamp(1.8rem,3.6vw,2.65rem)]">
        Start free. Scale when you ship.
      </h2>
      <p class="mt-3.5 text-[1.05rem] text-ink-muted">
        Every plan includes the full interactive API reference, live request
        console, and OpenAPI 3.1 specs. No surprises.
      </p>
    </div>

    <div class="grid gap-5 lg:grid-cols-3" data-reveal style="transition-delay:60ms">
      {
        PRICING_TIERS.map((tier) => (
          <div
            class:list={[
              "pricing-card flex flex-col rounded-2xl border p-8",
              tier.highlighted
                ? "pricing-card--featured border-brand bg-surface shadow-(--shadow-glow)"
                : "border-rule bg-surface",
            ]}
          >
            {tier.highlighted && (
              <div class="mb-5 -mt-1">
                <span class="pill pill--brand font-ui text-[0.72rem]">Most popular</span>
              </div>
            )}

            <div class="mb-6">
              <h3 class="font-ui text-[0.85rem] font-semibold uppercase tracking-wider text-ink-faint">
                {tier.name}
              </h3>
              <div class="mt-2 flex items-end gap-1.5">
                <span class="font-display text-[clamp(2rem,4vw,2.8rem)] font-semibold leading-none tracking-tight text-ink">
                  {tier.price}
                </span>
                <span class="mb-1 text-[0.9rem] text-ink-subtle">{tier.period}</span>
              </div>
              <p class="mt-3 text-[0.9rem] text-ink-muted">{tier.description}</p>
            </div>

            <ul class="m-0 mb-8 grid list-none gap-2.5 p-0">
              {tier.features.map((f) => (
                <li class="flex items-start gap-2.5">
                  <span
                    class:list={[
                      "mt-0.5 grid h-4.5 w-4.5 shrink-0 place-items-center rounded-full",
                      f.included
                        ? "bg-brand-soft text-brand-deep"
                        : "bg-surface-3 text-ink-faint",
                    ]}
                  >
                    {f.included
                      ? <Icon name="check" class="h-2.5 w-2.5" />
                      : <span class="h-px w-2.5 bg-current block" />
                    }
                  </span>
                  <span
                    class:list={[
                      "text-[0.9rem]",
                      f.included ? "text-ink-muted" : "text-ink-faint line-through",
                    ]}
                  >
                    {f.text}
                  </span>
                </li>
              ))}
            </ul>

            <a
              href={tier.ctaHref}
              class:list={[
                "btn mt-auto w-full justify-center",
                tier.highlighted ? "btn-primary" : "",
              ]}
            >
              {tier.cta}
            </a>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-center text-[0.85rem] text-ink-faint" data-reveal style="transition-delay:120ms">
      All plans include multi-region edge routing, OpenAPI 3.1 specs, and the interactive reference console. &mdash;
      <a href={LINKS.docs} class="text-brand-deep hover:underline" target="_blank" rel="noopener">Compare plans ↗</a>
    </p>
  </div>
</section>
