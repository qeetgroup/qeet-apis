---
import { PLATFORM_METRICS } from "../data/catalog";
---

<!-- Full-bleed dark section that breaks the light run — same pattern as MetricBand -->
<section class="relative overflow-hidden bg-[#0c0b0a] py-[clamp(3.5rem,8vw,6rem)] text-[#fafafa] dark:border-y dark:border-rule dark:bg-surface">
  <!-- Ambient brand glow -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background:radial-gradient(50% 80% at 50% -10%, color-mix(in oklab, var(--brand) 18%, transparent), transparent 60%)"
    aria-hidden="true"
  ></div>
  <!-- Faint dot grid -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.4]"
    style="background-image:radial-gradient(color-mix(in oklab,#fff 6%,transparent) 1px, transparent 1px); background-size:32px 32px; -webkit-mask-image:radial-gradient(80% 60% at 50% 0%, #000, transparent 80%); mask-image:radial-gradient(80% 60% at 50% 0%, #000, transparent 80%)"
    aria-hidden="true"
  ></div>

  <div class="container container-wide relative">
    <div class="mb-12 max-w-[50ch]" data-reveal>
      <span class="eyebrow inline-flex items-center gap-2.5 text-brand-bright">
        <span class="h-px w-7 bg-brand-bright/70"></span>
        By the numbers
      </span>
      <h2 class="mt-3 text-[clamp(1.8rem,3.6vw,2.65rem)] text-white">
        Platform-wide, every day.
      </h2>
    </div>

    <div class="grid gap-y-10 gap-x-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        PLATFORM_METRICS.map((m, i) => (
          <div
            class="flex flex-col gap-2"
            data-reveal
            style={`transition-delay:${i * 60}ms`}
          >
            <div class="flex items-end gap-1 font-display leading-none tracking-tight">
              {m.prefix && (
                <span class="text-[clamp(1.4rem,3vw,2rem)] font-semibold text-brand-bright">{m.prefix}</span>
              )}
              <span
                class="text-[clamp(2.8rem,5.5vw,4rem)] font-semibold text-white"
                data-count={m.value}
                data-suffix={m.suffix}
              >
                {m.value}{m.suffix}
              </span>
            </div>
            <p class="font-ui text-[0.95rem] font-medium text-white/90">{m.label}</p>
            <p class="text-[0.82rem]" style="color:color-mix(in oklab,#fff 52%,transparent)">{m.sublabel}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
