---
import Icon from "./Icon.astro";
interface Props {
  icon: Parameters<typeof Icon>[0]["name"];
  title: string;
  [key: string]: unknown;
}
const { icon, title, class: className, ...rest } = Astro.props;
---

<div
  class={`bezel card-hover group h-full ${className ?? ""}`}
  {...rest}
>
  <div class="bezel-core flex h-full flex-col gap-3 p-5">
    <div class="flex items-center justify-between gap-3">
      <span class="grid h-9 w-9 place-items-center rounded-full bg-surface-2 text-brand-deep transition duration-700 ease-(--ease-spring) group-hover:translate-x-1 group-hover:-translate-y-px">
        <Icon name={icon} class="h-[1.08rem] w-[1.08rem] stroke-[1.55]" />
      </span>
      <span class="h-px flex-1 bg-rule"></span>
      <span class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-ink-faint">api</span>
    </div>
    <h3 class="text-[1.08rem]">{title}</h3>
    <p class="m-0 text-[0.94rem] text-ink-subtle"><slot /></p>
  </div>
</div>
