---
import { LINKS } from "../data/catalog";
const year = new Date().getFullYear();
const logo = "h-[1.75rem] w-[1.75rem] rounded-[7px]";
const head = "mb-3.5 font-ui text-[0.78rem] font-semibold uppercase tracking-wider text-ink-faint";
const link = "text-[0.95rem] text-ink-muted transition hover:text-brand";
---

<footer class="mt-16 border-t border-rule bg-surface pb-10 pt-14">
  <div class="container container-wide">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-[1.4fr_repeat(3,1fr)] md:gap-10">
      <div>
        <a href="/" class="flex items-center gap-2.5 font-display font-semibold text-ink" aria-label="Qeet APIs — home">
          <img src="/brand/logo-light.svg" alt="" width="28" height="28" class={`${logo} block dark:hidden`} />
          <img src="/brand/logo-dark.svg" alt="" width="28" height="28" class={`${logo} hidden dark:block`} />
          <span class="text-[1.1rem] tracking-tight">qeet</span>
          <span class="-translate-y-px rounded-[5px] bg-brand-soft px-1.5 py-0.5 font-mono text-[0.7rem] font-medium text-brand-deep">apis</span>
        </a>
        <p class="mt-3.5 max-w-[30ch] text-[0.95rem] text-ink-subtle">
          One interactive reference for every Qeet product API — built for
          developers shipping on the Qeet platform.
        </p>
      </div>

      <div>
        <h4 class={head}>Develop</h4>
        <ul class="m-0 grid list-none gap-2 p-0">
          <li><a class={link} href={LINKS.reference}>API Reference</a></li>
          <li><a class={link} href={LINKS.quickstart}>Quickstart</a></li>
          <li><a class={link} href={LINKS.authentication}>Authentication</a></li>
          <li><a class={link} href={LINKS.errors}>Errors &amp; rate limits</a></li>
          <li><a class={link} href={LINKS.sdks}>SDKs</a></li>
        </ul>
      </div>

      <div>
        <h4 class={head}>Products</h4>
        <ul class="m-0 grid list-none gap-2 p-0">
          <li><a class={link} href={LINKS.reference}>Qeet ID</a></li>
          <li><a class={link} href={LINKS.reference}>Qeet Notify</a></li>
          <li><a class={link} href={LINKS.docs} rel="noopener">Product docs ↗</a></li>
        </ul>
      </div>

      <div>
        <h4 class={head}>Resources</h4>
        <ul class="m-0 grid list-none gap-2 p-0">
          <li><a class={link} href={LINKS.changelog}>Changelog</a></li>
          <li><a class={link} href={LINKS.console} rel="noopener">Console ↗</a></li>
          <li><a class={link} href={LINKS.status} rel="noopener">Status ↗</a></li>
          <li><a class={link} href={LINKS.docs} rel="noopener">Docs ↗</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-wrap justify-between gap-4 border-t border-rule pt-6 text-[0.88rem] text-ink-faint">
      <span>© {year} Qeet Group. All rights reserved.</span>
      <span>apis.qeet.in · built with Astro + Scalar</span>
    </div>
  </div>
</footer>
