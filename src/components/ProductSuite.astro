---
import Icon from "./Icon.astro";
import { PRODUCTS } from "../data/catalog";
---

<div class="grid gap-[1.1rem] sm:grid-cols-2 lg:grid-cols-3">
  {
    PRODUCTS.map((p, i) => {
      const live = p.status === "live";
      return (
        <a
          href={p.href}
          data-reveal
          style={`transition-delay:${i * 60}ms`}
          rel={p.external ? "noopener" : undefined}
          target={p.external ? "_blank" : undefined}
          aria-label={`${p.name} — ${live ? "open the API reference" : "coming to the API"}`}
          class="card-hover group relative flex h-full flex-col gap-3 overflow-hidden rounded-xl border border-rule bg-surface p-6"
        >
          {/* corner glow */}
          <div
            class="pointer-events-none absolute -right-10 -top-10 h-28 w-28 rounded-full opacity-0 blur-2xl transition-opacity duration-300 group-hover:opacity-100"
            style="background:radial-gradient(circle, var(--brand-soft), transparent 70%)"
            aria-hidden="true"
          />
          <div class="relative flex items-start justify-between gap-3">
            <span class="grid h-[2.9rem] w-[2.9rem] place-items-center rounded-lg bg-brand-soft text-brand-deep transition-transform duration-300 group-hover:scale-110">
              <Icon name={p.icon as any} class="h-[1.4rem] w-[1.4rem]" />
            </span>
            {live ? (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-transparent bg-[color-mix(in_oklab,var(--success)_14%,transparent)] px-2.5 py-1 font-ui text-[0.7rem] font-semibold text-success">
                <span class="live-dot h-1.5 w-1.5 rounded-full bg-success" />
                Live
              </span>
            ) : (
              <span class="pill">Coming soon</span>
            )}
          </div>
          <div class="relative">
            <span class="font-ui text-[0.74rem] font-semibold uppercase tracking-wider text-ink-faint">
              {p.kind}
            </span>
            <h3 class="mt-0.5 font-display text-[1.25rem]">{p.name}</h3>
          </div>
          <p class="relative m-0 flex-1 text-[0.93rem] text-ink-subtle">{p.blurb}</p>
          <span
            class={`relative flex items-center gap-2 font-ui text-[0.9rem] font-semibold ${live ? "text-brand-deep" : "text-ink-faint"}`}
          >
            {live ? "Open reference" : "View docs"}
            <Icon
              name={p.external ? "arrow-up-right" : "arrow-right"}
              class="h-[1em] w-[1em] transition-transform group-hover:translate-x-0.75"
            />
          </span>
        </a>
      );
    })
  }
</div>
