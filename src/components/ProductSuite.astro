---
import Icon from "./Icon.astro";
import { PRODUCTS } from "../data/catalog";
---

<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-12">
  {
    PRODUCTS.map((p, i) => {
      const live = p.status === "live";
      return (
        <a
          href={p.href}
          data-reveal
          style={`transition-delay:${i * 60}ms`}
          rel={p.external ? "noopener" : undefined}
          target={p.external ? "_blank" : undefined}
          aria-label={`${p.name} — ${live ? "open the API reference" : "coming to the API"}`}
          class:list={[
            "bezel card-hover group relative h-full",
            i === 0 || i === 1 ? "lg:col-span-6" : "lg:col-span-3",
          ]}
        >
          <div class="bezel-core flex h-full flex-col gap-4 p-5 sm:p-6">
            <div class="relative flex items-start justify-between gap-3">
              <span class="grid h-[2.75rem] w-[2.75rem] place-items-center rounded-full bg-surface-2 text-brand-deep transition duration-700 ease-(--ease-spring) group-hover:translate-x-1 group-hover:-translate-y-px">
                <Icon name={p.icon as any} class="h-[1.2rem] w-[1.2rem] stroke-[1.55]" />
              </span>
              {live ? (
                <span class="inline-flex items-center gap-1.5 rounded-full border border-transparent bg-[color-mix(in_oklab,var(--success)_14%,transparent)] px-2.5 py-1 font-ui text-[0.7rem] font-semibold text-success">
                  <span class="live-dot h-1.5 w-1.5 rounded-full bg-success" />
                  Live
                </span>
              ) : (
                <span class="pill">Coming soon</span>
              )}
            </div>
            <div class="relative">
              <span class="font-ui text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink-faint">
                {p.kind}
              </span>
              <h3 class="mt-1 font-display text-[1.35rem]">{p.name}</h3>
            </div>
            <p class="relative m-0 flex-1 text-[0.94rem] text-ink-subtle">{p.blurb}</p>
            <span
              class={`relative inline-flex items-center gap-2 font-ui text-[0.9rem] font-semibold ${live ? "text-brand-deep" : "text-ink-faint"}`}
            >
              {live ? "Open reference" : "View docs"}
              <span class="grid h-7 w-7 place-items-center rounded-full bg-surface-2 transition duration-700 ease-(--ease-spring) group-hover:translate-x-1 group-hover:-translate-y-px">
                <Icon
                  name={p.external ? "arrow-up-right" : "arrow-right"}
                  class="h-3.5 w-3.5 stroke-[1.55]"
                />
              </span>
            </span>
          </div>
        </a>
      );
    })
  }
</div>
