---
import Icon from "./Icon.astro";
import { RELIABILITY } from "../data/catalog";
---

<!-- Full-bleed dark band that breaks the run of light card grids. Architecture-
     true guarantees only — no fabricated SLA numbers (see RELIABILITY). -->
<section class="relative overflow-hidden bg-[#0c0b0a] py-[clamp(3.5rem,8vw,6rem)] text-[#fafafa] dark:border-y dark:border-rule dark:bg-surface">
  <!-- ambient brand glow -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background:radial-gradient(58% 90% at 50% -12%, color-mix(in oklab, var(--brand) 22%, transparent), transparent 62%)"
    aria-hidden="true"
  >
  </div>
  <!-- faint dot grid -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.5]"
    style="background-image:radial-gradient(color-mix(in oklab,#fff 8%,transparent) 1px, transparent 1px); background-size:26px 26px; -webkit-mask-image:radial-gradient(80% 70% at 50% 0%, #000, transparent 78%); mask-image:radial-gradient(80% 70% at 50% 0%, #000, transparent 78%)"
    aria-hidden="true"
  >
  </div>

  <div class="container container-wide relative">
    <div class="mb-11 max-w-[56ch]" data-reveal>
      <span class="eyebrow inline-flex items-center gap-2.5 text-brand-bright">
        <span class="h-px w-7 bg-brand-bright/70"></span>
        Engineered for production
      </span>
      <h2 class="mt-3 text-[clamp(1.8rem,3.6vw,2.65rem)] text-white">
        Built to be depended on.
      </h2>
      <p class="mt-3.5 text-[1.05rem]" style="color:color-mix(in oklab,#fff 72%,transparent)">
        No moving targets. The same guarantees back every product on the
        platform — from your first call to production scale.
      </p>
    </div>

    <div class="grid gap-x-8 gap-y-9 sm:grid-cols-2 lg:grid-cols-3">
      {
        RELIABILITY.map((g, i) => (
          <div
            class="group relative flex flex-col gap-2.5"
            data-reveal
            style={`transition-delay:${i * 55}ms`}
          >
            <span
              class="grid h-[2.7rem] w-[2.7rem] place-items-center rounded-lg text-brand-bright transition-transform duration-300 group-hover:scale-110"
              style="background:color-mix(in oklab, var(--brand) 16%, transparent)"
            >
              <Icon name={g.icon as any} class="h-[1.35rem] w-[1.35rem]" />
            </span>
            <h3 class="text-[1.1rem] text-white">{g.title}</h3>
            <p class="m-0 text-[0.93rem]" style="color:color-mix(in oklab,#fff 64%,transparent)">
              {g.body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
