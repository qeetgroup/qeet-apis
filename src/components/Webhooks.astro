---
// Webhooks — subscribed events, an HMAC-signed delivery and a live delivery log.
// Split layout, visual on the right. Canvas background.
import SectionHead from "./SectionHead.astro";
import ArrowLink from "./ArrowLink.astro";
import Icon from "./Icon.astro";
import { LINKS } from "../data/catalog";

const bullets = [
  ["Signed, always.", "Every delivery carries an HMAC signature — verify authenticity before you trust it."],
  ["No polling, ever.", "Subscribe to the events you care about and react the moment they happen."],
  ["Reliable delivery.", "Automatic retries with exponential backoff, plus one-click replay from the console."],
  ["Full visibility.", "Inspect every attempt, payload and response — no black boxes."],
];

const events = ["user.created", "message.delivered", "invoice.paid", "payment.failed"];

const log = [
  { ev: "user.created", status: "200", label: "OK", attempt: "1", time: "38ms", tone: "ok" },
  { ev: "message.delivered", status: "200", label: "OK", attempt: "1", time: "44ms", tone: "ok" },
  { ev: "invoice.paid", status: "—", label: "retrying", attempt: "2", time: "backoff", tone: "warn" },
  { ev: "payment.failed", status: "200", label: "OK", attempt: "1", time: "51ms", tone: "ok" },
];
---

<section class="py-[clamp(3.5rem,8vw,6.5rem)]" id="webhooks">
  <div class="container container-wide">
    <div class="grid items-center gap-x-14 gap-y-10 lg:grid-cols-2">
      <!-- copy -->
      <div>
        <SectionHead eyebrow="Webhooks" title="Real-time events you can rely on.">
          Push the moments that matter to your systems — securely signed, reliably
          delivered, and fully observable from first fire to final ack.
        </SectionHead>
        <ul class="mt-7 grid gap-4">
          {
            bullets.map(([h, t]) => (
              <li class="flex gap-3" data-reveal>
                <span class="mt-px grid h-5 w-5 flex-none place-items-center rounded-full bg-brand-soft text-brand-deep">
                  <Icon name="check" class="h-3 w-3" />
                </span>
                <span class="text-[0.96rem] text-ink-muted">
                  <b class="font-semibold text-ink">{h}</b> {t}
                </span>
              </li>
            ))
          }
        </ul>
        <div class="mt-8" data-reveal>
          <ArrowLink href={LINKS.reference} label="Explore webhook events" />
        </div>
      </div>

      <!-- visual: webhooks -->
      <div data-reveal style="transition-delay:120ms">
        <div class="overflow-hidden rounded-2xl border border-rule bg-surface shadow-[var(--shadow-lg)]">
          <!-- header -->
          <div class="flex items-center gap-2 border-b border-rule bg-surface-2 px-4 py-2.5">
            <Icon name="webhook" class="h-4 w-4 text-brand-deep" />
            <span class="font-ui text-[0.8rem] font-semibold text-ink">Webhook deliveries</span>
            <span class="ml-auto flex items-center gap-1.5 font-ui text-[0.7rem] text-ink-faint">
              <span class="live-dot h-1.5 w-1.5 rounded-full bg-success"></span> streaming
            </span>
          </div>

          <!-- subscribed events -->
          <div class="flex flex-wrap gap-1.5 border-b border-rule px-4 py-3">
            {
              events.map((e) => (
                <span class="rounded-md border border-rule bg-surface-2/60 px-2 py-0.5 font-mono text-[0.7rem] text-ink-subtle">
                  {e}
                </span>
              ))
            }
          </div>

          <!-- signed delivery target -->
          <div class="border-b border-rule px-4 py-3 font-mono text-[0.76rem] leading-relaxed">
            <p><span class="font-semibold" style="color:var(--m-post)">POST</span> <span class="text-ink">https://api.acme.com/hooks</span></p>
            <p class="mt-1 truncate text-ink-muted"><span class="text-brand-deep">X-Qeet-Signature:</span> t=1751792…, v1=3a8f9c…</p>
          </div>

          <!-- delivery log -->
          <div class="grid grid-cols-[1fr_auto_auto] gap-x-4 px-4 py-1 font-ui text-[0.66rem] font-semibold uppercase tracking-wide text-ink-faint">
            <span>Event</span><span>Attempt</span><span class="text-right">Status</span>
          </div>
          <ul class="m-0 list-none p-0">
            {
              log.map((r) => (
                <li class="grid grid-cols-[1fr_auto_auto] items-center gap-x-4 border-t border-rule px-4 py-2.5">
                  <code class="truncate font-mono text-[0.76rem] text-ink">{r.ev}</code>
                  <span class="font-mono text-[0.72rem] text-ink-subtle">{r.attempt}</span>
                  <span class="flex items-center justify-end gap-1.5">
                    {r.tone === "warn" ? (
                      <span class="inline-flex items-center gap-1 rounded px-1.5 py-0.5 font-mono text-[0.68rem] font-semibold text-warning" style="background:color-mix(in oklab,var(--warning) 14%,transparent)">
                        <Icon name="refresh-cw" class="h-3 w-3" /> {r.label}
                      </span>
                    ) : (
                      <span class="inline-flex items-center gap-1 rounded px-1.5 py-0.5 font-mono text-[0.68rem] font-semibold text-success" style="background:color-mix(in oklab,var(--success) 14%,transparent)">
                        {r.status} {r.label}
                      </span>
                    )}
                  </span>
                </li>
              ))
            }
          </ul>

          <!-- footer -->
          <div class="flex items-center gap-4 border-t border-rule bg-surface-2/50 px-4 py-2 font-ui text-[0.7rem] text-ink-faint">
            <span>HMAC signed</span><span>Exponential backoff</span><span class="ml-auto">at-least-once</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
