---
import { FAQ_ITEMS } from "../data/catalog";
---

<section class="border-y border-rule bg-surface py-[clamp(3.5rem,8vw,6.5rem)]" id="faq">
  <div class="container container-wide">
    <div class="grid gap-14 lg:grid-cols-[1fr_1.6fr]">
      <!-- Left: heading -->
      <div data-reveal>
        <span class="eyebrow inline-flex items-center gap-2.5">
          <span class="h-px w-7 bg-brand/60"></span>
          FAQ
        </span>
        <h2 class="mt-3 text-[clamp(1.8rem,3.6vw,2.65rem)]">
          Questions from real developers.
        </h2>
        <p class="mt-3.5 text-[1.05rem] text-ink-muted">
          Still have questions? Open the reference and run a live request — or
          reach us at <a class="text-brand-deep hover:underline" href="mailto:support@qeet.in">support@qeet.in</a>.
        </p>
      </div>

      <!-- Right: accordion -->
      <div class="flex flex-col" data-reveal style="transition-delay:80ms">
        {
          FAQ_ITEMS.map((item, i) => (
            <details
              class="faq-item group border-b border-rule"
              name="faq-group"
            >
              <summary class="faq-summary flex cursor-pointer list-none items-center justify-between gap-4 py-5 font-ui text-[0.98rem] font-medium text-ink transition-colors hover:text-brand-deep [&::-webkit-details-marker]:hidden">
                {item.question}
                <svg
                  class="faq-chevron h-4 w-4 shrink-0 text-ink-faint transition-transform duration-200"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </summary>
              <div class="faq-body overflow-hidden">
                <p
                  class="pb-5 pr-8 text-[0.93rem] leading-relaxed text-ink-muted [&_a]:text-brand-deep [&_a]:underline [&_code]:rounded [&_code]:border [&_code]:border-rule [&_code]:bg-surface-2 [&_code]:px-1 [&_code]:font-mono [&_code]:text-[0.82em] [&_code]:text-brand-deep"
                  set:html={item.answer}
                />
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* Smooth accordion open/close */
  .faq-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.28s var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .faq-body > * {
    min-height: 0;
    overflow: hidden;
  }
  details[open] .faq-body {
    grid-template-rows: 1fr;
  }
  details[open] .faq-chevron {
    transform: rotate(180deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-body {
      transition: none;
    }
  }
</style>
