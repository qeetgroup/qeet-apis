---
import { TESTIMONIALS } from "../data/catalog";
---

<section class="border-y border-rule bg-surface py-[clamp(3.5rem,8vw,6.5rem)]" id="testimonials">
  <div class="container container-wide">
    <div class="mb-12 max-w-[54ch]" data-reveal>
      <span class="eyebrow inline-flex items-center gap-2.5">
        <span class="h-px w-7 bg-brand/60"></span>
        What developers say
      </span>
      <h2 class="mt-3 text-[clamp(1.8rem,3.6vw,2.65rem)]">
        Trusted in production.
      </h2>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {
        TESTIMONIALS.map((t, i) => (
          <figure
            class="flex flex-col justify-between rounded-2xl border border-rule bg-bg p-8 shadow-(--shadow-sm)"
            style={`border-left: 3px solid var(--brand); transition-delay:${i * 80}ms`}
            data-reveal
          >
            <blockquote class="m-0 p-0">
              <p class="text-[0.98rem] leading-relaxed text-ink-muted before:content-['“'] after:content-['”']">
                {t.quote}
              </p>
            </blockquote>
            <figcaption class="mt-6 flex items-center gap-3">
              <div
                class="grid h-10 w-10 shrink-0 place-items-center rounded-full font-ui text-[0.78rem] font-semibold text-brand-ink"
                style="background:var(--brand)"
              >
                {t.initials}
              </div>
              <div>
                <p class="font-ui text-[0.9rem] font-semibold text-ink">{t.name}</p>
                <p class="text-[0.8rem] text-ink-subtle">{t.role} · {t.company}</p>
              </div>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
