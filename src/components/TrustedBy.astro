---
import { BRAND_LOGOS, STATS } from "../data/catalog";
---

<section class="border-y border-rule bg-surface py-[clamp(3rem,7vw,5.5rem)]">
  <div class="container container-wide">
    <p
      class="mb-10 text-center font-ui text-[0.8rem] font-semibold uppercase tracking-[0.16em] text-ink-faint"
      data-reveal
    >
      Trusted by engineering teams worldwide
    </p>

    <!-- Logo strip -->
    <div
      class="mb-14 flex flex-wrap items-center justify-center gap-x-10 gap-y-5"
      data-reveal
      style="transition-delay:60ms"
    >
      {
        BRAND_LOGOS.map((name) => (
          <span class="font-display text-[1.05rem] font-semibold tracking-tight text-ink-subtle opacity-50 transition-opacity duration-200 hover:opacity-80 select-none">
            {name}
          </span>
        ))
      }
    </div>

    <!-- Platform stats -->
    <div class="grid grid-cols-2 gap-6 sm:grid-cols-4" data-reveal style="transition-delay:120ms">
      {
        STATS.map((s) => (
          <div class="flex flex-col gap-1.5 rounded-xl border border-rule bg-bg p-6 text-center">
            <span class="font-display text-[clamp(1.8rem,3.5vw,2.4rem)] font-semibold leading-none tracking-tight text-ink">
              {s.prefix ?? ""}
              <span data-count={s.value} data-suffix={s.suffix ?? ""}>{s.value}{s.suffix ?? ""}</span>
            </span>
            <span class="font-ui text-[0.82rem] text-ink-subtle">{s.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
