---
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { LINKS } from "../data/catalog";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => path === href || path.startsWith(href + "/");

const developerLinks = [
  { href: LINKS.quickstart, label: "Quickstart", desc: "Ship your first request in minutes" },
  { href: LINKS.authentication, label: "Authentication", desc: "API keys, OAuth 2.1, and OIDC" },
  { href: LINKS.sdks, label: "SDKs", desc: "cURL, JavaScript, Go, Python" },
  { href: LINKS.errors, label: "Errors & Rate Limits", desc: "Status codes, retry signals" },
  { href: LINKS.changelog, label: "Changelog", desc: "New endpoints and spec updates" },
];
const docsLinks = [
  { href: LINKS.reference, label: "API Reference", desc: "Interactive, live request console" },
  { href: LINKS.postman, label: "Postman Collection", desc: "Import and run in Postman" },
  { href: LINKS.docs, label: "Product Docs", desc: "Guides for each Qeet product", external: true },
];
const logo = "h-[1.85rem] w-[1.85rem] rounded-[7px]";
---

<header
  class="sticky top-0 z-200 h-(--header-h) border-b border-rule backdrop-blur-md backdrop-saturate-150"
  style="background:color-mix(in oklab, var(--bg) 78%, transparent)"
>
  <div class="container container-wide flex h-full items-center gap-4 xl:gap-6">
    <!-- Logo -->
    <a
      href="/"
      class="flex shrink-0 items-center gap-2.5 font-display font-semibold leading-none text-ink"
      aria-label="Qeet APIs — home"
    >
      <img src="/brand/logo-light.svg" alt="" width="30" height="30" class={`${logo} block dark:hidden`} />
      <img src="/brand/logo-dark.svg" alt="" width="30" height="30" class={`${logo} hidden dark:block`} />
      <span class="text-[1.18rem] leading-none tracking-tight">qeet</span>
      <span
        class="inline-flex items-center rounded-[5px] bg-brand-soft px-1.5 py-1 font-mono text-[0.7rem] font-medium leading-none text-brand-deep max-sm:hidden"
        >apis</span
      >
    </a>

    <!-- Primary nav — desktop -->
    <nav class="ml-6 hidden items-center gap-0.5 font-ui lg:flex" id="site-nav" aria-label="Primary">
      <!-- Products -->
      <a
        href="/#products"
        aria-current={path === "/" ? undefined : undefined}
        class="nav-link px-2.5 py-2 text-[0.9rem] font-medium text-ink-muted transition-colors hover:text-ink"
      >
        Products
      </a>

      <!-- Developers dropdown -->
      <div class="nav-dropdown group relative">
        <button
          type="button"
          class="nav-link flex items-center gap-1 px-2.5 py-2 text-[0.9rem] font-medium text-ink-muted transition-colors hover:text-ink"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="nav-developers"
        >
          Developers
          <Icon name="chevron-down" class="h-3.5 w-3.5 transition-transform duration-200 group-focus-within:rotate-180" />
        </button>
        <div
          id="nav-developers"
          class="nav-panel invisible absolute left-0 top-full min-w-88 opacity-0 transition-all duration-200"
          role="menu"
        >
          <div class="mt-2 overflow-hidden rounded-xl border border-rule bg-surface shadow-(--shadow-lg)">
            {
              developerLinks.map((item) => (
                <a
                  href={item.href}
                  role="menuitem"
                  class="flex flex-col gap-0.5 px-4 py-3 transition-colors hover:bg-surface-2 focus:bg-surface-2 focus:outline-none"
                  aria-current={isActive(item.href) ? "page" : undefined}
                >
                  <span class="text-[0.9rem] font-medium text-ink aria-[current=page]:text-brand-deep">{item.label}</span>
                  <span class="text-[0.8rem] text-ink-subtle">{item.desc}</span>
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Documentation dropdown -->
      <div class="nav-dropdown group relative">
        <button
          type="button"
          class="nav-link flex items-center gap-1 px-2.5 py-2 text-[0.9rem] font-medium text-ink-muted transition-colors hover:text-ink"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="nav-docs"
        >
          Documentation
          <Icon name="chevron-down" class="h-3.5 w-3.5 transition-transform duration-200 group-focus-within:rotate-180" />
        </button>
        <div
          id="nav-docs"
          class="nav-panel invisible absolute left-0 top-full min-w-[20rem] opacity-0 transition-all duration-200"
          role="menu"
        >
          <div class="mt-2 overflow-hidden rounded-xl border border-rule bg-surface shadow-(--shadow-lg)">
            {
              docsLinks.map((item) => (
                <a
                  href={item.href}
                  role="menuitem"
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noopener" : undefined}
                  class="flex flex-col gap-0.5 px-4 py-3 transition-colors hover:bg-surface-2 focus:bg-surface-2 focus:outline-none"
                >
                  <span class="flex items-center gap-1.5 text-[0.9rem] font-medium text-ink">
                    {item.label}
                    {item.external && <Icon name="external-link" class="h-3 w-3 text-ink-faint" />}
                  </span>
                  <span class="text-[0.8rem] text-ink-subtle">{item.desc}</span>
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <a href="/#pricing" class="nav-link px-2.5 py-2 text-[0.9rem] font-medium text-ink-muted transition-colors hover:text-ink">
        Pricing
      </a>
      <a href="/#enterprise" class="nav-link px-2.5 py-2 text-[0.9rem] font-medium text-ink-muted transition-colors hover:text-ink">
        Enterprise
      </a>
    </nav>

    <!-- Right side actions -->
    <div class="ml-auto flex items-center gap-2">
      <a
        class="hidden px-3 py-1.5 font-ui text-[0.9rem] font-medium text-ink-muted transition-colors hover:text-ink sm:block"
        href={LINKS.console}
        target="_blank"
        rel="noopener"
      >
        Sign In
      </a>
      <a class="btn btn-primary hidden sm:flex" href={LINKS.quickstart}>
        Get Started
      </a>
      <a
        class="hidden h-[2.2rem] w-[2.2rem] place-items-center rounded border border-rule bg-surface text-ink-muted transition hover:border-rule-strong hover:text-ink md:grid"
        href={LINKS.github}
        target="_blank"
        rel="noopener"
        aria-label="Qeet on GitHub"
      >
        <Icon name="github" />
      </a>
      <ThemeToggle />
      <!-- Mobile hamburger -->
      <button
        type="button"
        class="grid h-[2.2rem] w-[2.2rem] place-items-center rounded border border-rule bg-surface text-ink lg:hidden"
        id="nav-toggle"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <Icon name="menu" class="block" id="icon-menu" />
        <Icon name="x" class="hidden" id="icon-x" />
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <div
    id="mobile-nav"
    class="hidden border-b border-rule bg-bg shadow-(--shadow-md) lg:hidden"
    aria-label="Mobile navigation"
  >
    <div class="container container-wide grid gap-1 py-4">
      <a href="/#products" class="mobile-nav-link">Products</a>
      <p class="mt-2 px-3 font-ui text-[0.72rem] font-semibold uppercase tracking-wider text-ink-faint">Developers</p>
      {
        developerLinks.map((item) => (
          <a href={item.href} class="mobile-nav-link pl-5 text-[0.9rem]">
            {item.label}
          </a>
        ))
      }
      <p class="mt-2 px-3 font-ui text-[0.72rem] font-semibold uppercase tracking-wider text-ink-faint">Documentation</p>
      {
        docsLinks.map((item) => (
          <a
            href={item.href}
            class="mobile-nav-link pl-5 text-[0.9rem]"
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noopener" : undefined}
          >
            {item.label}
            {item.external && " ↗"}
          </a>
        ))
      }
      <a href="/#pricing" class="mobile-nav-link">Pricing</a>
      <a href="/#enterprise" class="mobile-nav-link">Enterprise</a>
      <div class="mt-3 flex gap-2 border-t border-rule pt-3">
        <a class="btn flex-1 justify-center" href={LINKS.console} target="_blank" rel="noopener">Sign In</a>
        <a class="btn btn-primary flex-1 justify-center" href={LINKS.quickstart}>Get Started</a>
      </div>
    </div>
  </div>
</header>

<style>
  /* Desktop nav: brand underline wipe on hover/active */
  @media (min-width: 1024px) {
    .nav-link {
      position: relative;
    }
    a.nav-link::after {
      content: "";
      position: absolute;
      left: 0.625rem;
      right: 0.625rem;
      bottom: 0.2rem;
      height: 2px;
      border-radius: 2px;
      background: var(--brand);
      transform: scaleX(0);
      transform-origin: left center;
      transition: transform 0.22s var(--ease);
    }
    a.nav-link:hover::after,
    a.nav-link[aria-current="page"]::after {
      transform: scaleX(1);
    }
    @media (prefers-reduced-motion: reduce) {
      a.nav-link::after {
        transition: none;
      }
    }

    /* Dropdown open on hover AND focus-within */
    .nav-dropdown:hover .nav-panel,
    .nav-dropdown:focus-within .nav-panel {
      visibility: visible;
      opacity: 1;
    }
    .nav-dropdown:hover .nav-panel {
      transition-delay: 0ms;
    }
  }

  /* Mobile nav link */
  .mobile-nav-link {
    display: block;
    padding: 0.6rem 0.75rem;
    border-radius: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink-muted);
    transition: background-color 0.15s, color 0.15s;
  }
  .mobile-nav-link:hover {
    background: var(--surface-2);
    color: var(--ink);
  }
</style>

<script>
  // Mobile hamburger toggle
  const toggle = document.getElementById("nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  const iconMenu = document.getElementById("icon-menu");
  const iconX = document.getElementById("icon-x");

  toggle?.addEventListener("click", () => {
    const open = mobileNav?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    iconMenu?.classList.toggle("hidden", open);
    iconX?.classList.toggle("hidden", !open);
  });

  // Desktop dropdowns: keyboard accessible
  document.querySelectorAll<HTMLButtonElement>(".nav-dropdown > button").forEach((btn) => {
    const panel = btn.nextElementSibling as HTMLElement;
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
    });
    // Close on Escape
    btn.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        btn.setAttribute("aria-expanded", "false");
        btn.focus();
      }
    });
    // Sync aria-expanded with hover state for screen readers
    const dropdown = btn.closest(".nav-dropdown")!;
    dropdown.addEventListener("mouseenter", () => btn.setAttribute("aria-expanded", "true"));
    dropdown.addEventListener("mouseleave", () => btn.setAttribute("aria-expanded", "false"));
  });

  // Close mobile nav on anchor link click
  mobileNav?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      mobileNav.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
      iconMenu?.classList.remove("hidden");
      iconX?.classList.add("hidden");
    });
  });
</script>
