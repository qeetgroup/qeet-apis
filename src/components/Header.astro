---
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { LINKS } from "../data/catalog";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const nav = [
  { href: LINKS.quickstart, label: "Quickstart" },
  { href: LINKS.authentication, label: "Authentication" },
  { href: LINKS.errors, label: "Errors" },
  { href: LINKS.sdks, label: "SDKs" },
  { href: LINKS.changelog, label: "Changelog" },
];
const isActive = (href: string) => path === href || path.startsWith(href + "/");
const logo = "h-[1.85rem] w-[1.85rem] rounded-[7px]";
---

<header
  class="sticky top-0 z-[100] h-[var(--header-h)] border-b border-rule backdrop-blur-md backdrop-saturate-150"
  style="background:color-mix(in oklab, var(--bg) 78%, transparent)"
>
  <div class="container container-wide flex h-full items-center gap-6">
    <a
      href="/"
      class="flex items-center gap-2.5 font-display font-semibold leading-none text-ink"
      aria-label="Qeet APIs — home"
    >
      <img src="/brand/logo-light.svg" alt="" width="30" height="30" class={`${logo} block dark:hidden`} />
      <img src="/brand/logo-dark.svg" alt="" width="30" height="30" class={`${logo} hidden dark:block`} />
      <span class="text-[1.18rem] leading-none tracking-tight">qeet</span>
      <span
        class="inline-flex items-center rounded-[5px] bg-brand-soft px-1.5 py-1 font-mono text-[0.7rem] font-medium leading-none text-brand-deep max-sm:hidden"
        >apis</span
      >
    </a>

    <nav
      class="ml-auto flex items-center gap-1 font-ui"
      id="site-nav"
      aria-label="Primary"
    >
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class="nav-link relative px-2.5 py-2 text-[0.95rem] font-medium text-ink-muted transition-colors hover:text-ink aria-[current=page]:text-brand-deep"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2.5">
      <a
        class="hidden h-[2.4rem] w-[2.4rem] place-items-center rounded border border-rule bg-surface text-ink-muted transition hover:border-rule-strong hover:text-ink sm:grid"
        href={LINKS.github}
        target="_blank"
        rel="noopener"
        aria-label="Qeet on GitHub"
      >
        <Icon name="github" />
      </a>
      <a class="btn btn-primary" href={LINKS.reference}>
        <Icon name="book" />
        API Reference
      </a>
      <ThemeToggle />
      <button
        type="button"
        class="grid h-[2.4rem] w-[2.4rem] place-items-center rounded border border-rule bg-surface text-ink"
        id="nav-toggle"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="site-nav"
      >
        <Icon name="menu" />
      </button>
    </div>
  </div>
</header>

<style>
  /* Desktop nav: brand underline that wipes in from the left on hover/active. */
  @media (min-width: 768px) {
    .nav-link::after {
      content: "";
      position: absolute;
      left: 0.625rem;
      right: 0.625rem;
      bottom: 0.35rem;
      height: 2px;
      border-radius: 2px;
      background: var(--brand);
      transform: scaleX(0);
      transform-origin: left center;
      transition: transform 0.22s var(--ease);
    }
    .nav-link:hover::after,
    .nav-link[aria-current="page"]::after {
      transform: scaleX(1);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-link::after {
      transition: none;
    }
  }

  /* Mobile: collapse the nav into a toggled dropdown panel. */
  @media (max-width: 767px) {
    #site-nav {
      display: none;
      margin-left: 0;
    }
    #site-nav.open {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0.1rem;
      position: absolute;
      left: 0;
      right: 0;
      top: var(--header-h);
      padding: 0.75rem 1.5rem 1.25rem;
      background: var(--bg);
      border-bottom: 1px solid var(--rule);
      box-shadow: var(--shadow-md);
    }
  }
  @media (min-width: 768px) {
    #nav-toggle {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const nav = document.getElementById("site-nav");
  toggle?.addEventListener("click", () => {
    const open = nav?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!!open));
  });
</script>
