---
import Icon from "./Icon.astro";
import { SPECS, LINKS, sourceSlug } from "../data/catalog";
---

<div class="grid gap-[1.1rem] sm:grid-cols-2 lg:grid-cols-3">
  {
    SPECS.map((s, i) => (
      <a
        class="card-hover group flex h-full flex-col gap-3 rounded-xl border border-rule bg-surface p-[1.4rem]"
        href={`${LINKS.reference}#${sourceSlug(s.product)}`}
        data-reveal
        style={`transition-delay:${i * 55}ms`}
      >
        <div class="flex items-center justify-between gap-2">
          <span class="font-ui text-[0.74rem] font-semibold uppercase tracking-wider text-brand-deep">
            {s.product}
          </span>
          <span class="pill">OpenAPI</span>
        </div>
        <h3 class="font-display text-[1.2rem]">{s.title}</h3>
        <p class="m-0 flex-1 text-[0.93rem] text-ink-subtle">{s.blurb}</p>
        <span class="flex items-center gap-2 font-ui text-[0.9rem] font-semibold text-brand-deep">
          Open reference
          <Icon
            name="arrow-right"
            class="h-[1em] w-[1em] transition-transform group-hover:translate-x-0.75"
          />
        </span>
      </a>
    ))
  }
</div>
