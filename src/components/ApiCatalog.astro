---
import Icon from "./Icon.astro";
import { SPECS, LINKS, sourceSlug } from "../data/catalog";

const products = Array.from(new Set(SPECS.map((spec) => spec.product))).map((product) => ({
  product,
  specs: SPECS.filter((spec) => spec.product === product),
  href: `${LINKS.reference}#${sourceSlug(product)}`,
}));

const methods = ["GET", "POST", "PATCH", "PUT"];
---

<div class="bezel" data-reveal>
  <div class="bezel-core overflow-hidden">
    <div class="grid gap-px bg-rule lg:grid-cols-[0.82fr_1.18fr]">
      <aside class="bg-surface p-4 sm:p-5">
        <div class="rounded-[1.35rem] border border-rule bg-surface-2 p-3 shadow-(--shadow-bezel)">
          <div class="flex items-center gap-2 rounded-full border border-rule bg-surface px-3 py-2.5">
            <Icon name="search" class="h-4 w-4 stroke-[1.55] text-ink-faint" />
            <span class="font-ui text-[0.88rem] text-ink-subtle">Search APIs, schemas, events...</span>
            <span class="ml-auto rounded-full bg-surface-2 px-2 py-1 font-mono text-[0.66rem] text-ink-faint">⌘K</span>
          </div>
        </div>

        <div class="mt-5 grid gap-3">
          {
            products.map((group, i) => (
              <a
                href={group.href}
                class="group rounded-[1.35rem] border border-rule bg-surface p-4 shadow-(--shadow-bezel) transition duration-700 ease-(--ease-spring) hover:-translate-y-1 hover:border-rule-strong hover:shadow-(--shadow-md)"
                style={`transition-delay:${i * 45}ms`}
              >
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="m-0 font-ui text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-brand-deep">{group.product}</p>
                    <p class="m-0 mt-1 font-display text-[1.25rem] text-ink">{group.specs.length} live specs</p>
                  </div>
                  <span class="grid h-8 w-8 place-items-center rounded-full bg-surface-2 text-brand-deep transition duration-700 ease-(--ease-spring) group-hover:translate-x-1 group-hover:-translate-y-px">
                    <Icon name="arrow-right" class="h-3.5 w-3.5 stroke-[1.55]" />
                  </span>
                </div>
                <div class="mt-4 flex flex-wrap gap-1.5">
                  <span class="pill">OpenAPI 3.1</span>
                  <span class="pill pill--brand">live</span>
                </div>
              </a>
            ))
          }
        </div>
      </aside>

      <div class="bg-surface p-4 sm:p-5">
        <div class="grid gap-3">
          {
            SPECS.map((spec, i) => (
              <a
                class="group rounded-[1.45rem] border border-rule bg-surface p-4 shadow-(--shadow-bezel) transition duration-700 ease-(--ease-spring) hover:-translate-y-1 hover:border-rule-strong hover:bg-surface-2"
                href={`${LINKS.reference}#${sourceSlug(spec.product)}`}
                data-reveal
                style={`transition-delay:${i * 55}ms`}
              >
                <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
                  <div class="flex flex-1 items-start gap-3">
                    <span
                      class="method-chip shrink-0 text-[#1c5b8b] dark:text-[#6aa8d8]"
                      style="background:color-mix(in oklab, var(--m-post) 12%, transparent)"
                    >
                      {methods[i % methods.length]}
                    </span>
                    <div>
                      <div class="flex flex-wrap items-center gap-2">
                        <span class="font-ui text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-brand-deep">{spec.product}</span>
                        <span class="h-1 w-1 rounded-full bg-rule-strong"></span>
                        <span class="font-mono text-[0.68rem] text-ink-faint">{spec.url}</span>
                      </div>
                      <h3 class="m-0 mt-1 font-display text-[1.18rem] text-ink">{spec.title}</h3>
                      <p class="m-0 mt-1 max-w-[62ch] text-[0.92rem] text-ink-subtle">{spec.blurb}</p>
                    </div>
                  </div>
                  <span class="inline-flex items-center justify-center gap-2 rounded-full bg-ink px-3 py-2 font-ui text-[0.82rem] font-semibold text-bg transition duration-700 ease-(--ease-spring) group-hover:-translate-y-px">
                    Open
                    <span class="grid h-6 w-6 place-items-center rounded-full bg-bg/12">
                      <Icon name="arrow-right" class="h-3 w-3 stroke-[1.55]" />
                    </span>
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</div>
