---
import Icon from "./Icon.astro";
import { WHY_QEET } from "../data/catalog";
---

<section class="py-[clamp(3.5rem,8vw,6.5rem)]" id="why-qeet">
  <div class="container container-wide">
    <div class="mb-11 max-w-[54ch]" data-reveal>
      <span class="eyebrow inline-flex items-center gap-2.5">
        <span class="h-px w-7 bg-brand/60"></span>
        Why Qeet APIs
      </span>
      <h2 class="mt-3 text-[clamp(1.8rem,3.6vw,2.65rem)]">
        Built for how production APIs actually work.
      </h2>
      <p class="mt-3.5 text-[1.05rem] text-ink-muted">
        Six principles baked into every endpoint — not aspirational, not
        marketing. Backed by the OpenAPI specs you can read right now.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        WHY_QEET.map((r, i) => (
          <div
            class="card-hover group flex flex-col gap-4 rounded-xl border border-rule bg-surface p-7 transition-shadow duration-200 hover:shadow-(--shadow-md)"
            data-reveal
            style={`transition-delay:${i * 55}ms`}
          >
            <div class="flex items-start justify-between gap-4">
              <span
                class="grid h-11 w-11 shrink-0 place-items-center rounded-lg text-brand transition-transform duration-300 group-hover:scale-110"
                style="background:color-mix(in oklab, var(--brand) 12%, transparent)"
              >
                <Icon name={r.icon as any} class="h-5 w-5" />
              </span>
              <span class="font-mono text-[0.8rem] font-semibold text-brand-deep">
                {r.metric}
              </span>
            </div>
            <div>
              <h3 class="text-[1.05rem] font-semibold text-ink">{r.title}</h3>
              <p class="mt-1.5 text-[0.93rem] text-ink-muted">{r.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
