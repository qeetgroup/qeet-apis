---
import "../styles/tokens.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  /** Override the social card; defaults to the branded /brand/og.png. */
  ogImage?: string;
  /** Reference page hides the footer so Scalar runs full-height. */
  showFooter?: boolean;
  /** Reference page opts out of the centered content container. */
  fullBleed?: boolean;
}

const {
  title,
  description = "One interactive reference for every Qeet product API — Qeet ID and Qeet Notify. Try requests live, copy code in your language, and ship faster.",
  ogImage = "/brand/og.png",
  showFooter = true,
  fullBleed = false,
} = Astro.props;

const siteName = "Qeet APIs";
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/brand/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f26d0e" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script is:inline>
      // Set the theme before first paint to avoid a flash.
      (function () {
        try {
          var t = localStorage.getItem("qeet-theme");
          if (!t)
            t = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[200] focus:rounded focus:bg-ink focus:px-4 focus:py-2 focus:text-bg"
      href="#main">Skip to content</a
    >
    <Header />
    <main id="main" class={fullBleed ? "reference-main" : undefined}>
      <slot />
    </main>
    {showFooter && <Footer />}
  </body>
</html>
